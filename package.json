{
  "name": "reaperset",
  "version": "0.1.0",
  "description": "A REAPER-focused live playback and setlist controller.",
  "private": true,
  "main": "./out/main/index.js",
  "type": "module",
  "scripts": {
    "dev": "electron-vite dev",
    "build": "tsc --noEmit && electron-vite build",
    "build:web": "tsc --noEmit && electron-vite build && tsc -p tsconfig.server.json",
    "start:web": "node out/server/server/index.js",
    "typecheck": "tsc --noEmit",
    "preview": "electron-vite preview"
  },
  "dependencies": {
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "ws": "^8.18.0"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^4.3.4",
    "@types/node": "^22.10.2",
    "@types/react": "^19.0.2",
    "@types/react-dom": "^19.0.2",
    "@types/ws": "^8.5.13",
    "electron": "^43.1.0",
    "electron-vite": "^3.0.0",
    "typescript": "^5.7.2"
  }
}
